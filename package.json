{
  "name": "svg-to-ico",
  "version": "1.0.17",
  "description": "Utility that translates an SVG Image to a .ico format",
  "packageManager": "yarn@4.13.0",
  "type": "module",
  "main": "./dist/cjs/svg-to-ico.cjs.js",
  "module": "./dist/esm/svg-to-ico.js",
  "types": "./dist/types/svg-to-ico.d.ts",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/svg-to-ico.d.ts",
        "default": "./dist/esm/svg-to-ico.js"
      },
      "require": {
        "types": "./dist/types/svg-to-ico.d.ts",
        "default": "./dist/cjs/svg-to-ico.cjs.js"
      }
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "build:esm": "tsc",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jtrauntvein/svg-to-ico.git"
  },
  "keywords": [
    "svg",
    "icon",
    "image",
    "convert"
  ],
  "author": "jtrauntvein@gmail.com",
  "license": "MIT",
  "homepage": "https://github.com/jtrauntvein/svg-to-ico.git/svg-to-ico#readme",
  "dependencies": {
    "ico-endec": "^0.1.6",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^24.11.0",
    "eslint": "^10.0.2",
    "jiti": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "bin": "./dist/cjs/cli.js",
  "files": [
    "dist"
  ]
}
